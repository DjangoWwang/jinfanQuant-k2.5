# ============================================
# FOF投研平台环境变量配置
# 复制为 .env 并填写必填项
# ============================================

# ---- 必填: 数据库 ----
DB_PASSWORD=          # PostgreSQL 密码 (必填，生产环境使用强密码)
DB_PORT=5432

# ---- 必填: 应用密钥 ----
SECRET_KEY=           # JWT 签名密钥 (必填，使用 openssl rand -hex 32 生成)

# ---- 必填: 前端API地址 ----
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1  # 浏览器可访问的后端地址 (生产环境改为实际域名)

# ---- Redis ----
REDIS_PORT=6379

# ---- 后端 ----
BACKEND_PORT=8000
BACKEND_WORKERS=2
CORS_ORIGINS=http://localhost:3000
TRUST_PROXY_HEADERS=false

# ---- 前端 ----
FRONTEND_PORT=3000

# ---- FOF99 数据源 (可选) ----
FOF99_USERNAME=
FOF99_PASSWORD=
FOF99_DEVICE_ID=

# ---- 管理员初始化 ----
ADMIN_SETUP_KEY=

# ---- Celery ----
CELERY_CONCURRENCY=2

# ---- 定时任务时间 (HH:MM, Asia/Shanghai) ----
BEAT_DAILY_REFRESH_TIME=06:00
BEAT_RISK_CHECK_TIME=09:30
BEAT_NAV_CALC_TIME=20:00

# ---- 风险参数 ----
RISK_FREE_RATE_TYPE=fixed
RISK_FREE_RATE_VALUE=0.025
